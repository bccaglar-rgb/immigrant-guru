# ──────────────────────────────────────────────────────────────
# Bitrium — Environment Variables Template
# cp deploy/.env.example deploy/.env
# Fill in all required values before running docker compose
# ──────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────
DB_NAME=bitrium
DB_USER=bitrium
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Encryption ─────────────────────────────────────────────────
# 64 hex chars (32 bytes). Generate: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── JWT ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ── Admin User ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@bitrium.io
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Tron Payments (optional) ───────────────────────────────────
TRON_NODE_URL=
TRON_WALLET=

# ── Bot Limits ─────────────────────────────────────────────────
MAX_BOTS_PER_USER=50

# ── Hub Mode ───────────────────────────────────────────────────
# Faz 1: false (hub runs inside API worker 0)
# Faz 2+: true (hub runs as separate market-hub service)
HUB_EXTERNAL=false

# ── Bot Breaker Thresholds (optional tuning) ───────────────────
# BB_MAX_MARKET_TRADES=50
# BB_MAX_STRATEGY_FAILS=10
# BB_MAX_USER_FAILS=5
