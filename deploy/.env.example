# ──────────────────────────────────────────────────────────────
# Bitrium — Environment Variables Template
# cp deploy/.env.example deploy/.env
# Fill in all required values before running docker compose
# ──────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────
DB_NAME=bitrium
DB_USER=bitrium
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Encryption ─────────────────────────────────────────────────
# 64 hex chars (32 bytes). Generate: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ── JWT ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ── Admin User ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@bitrium.io
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Tron Payments ──────────────────────────────────────────────
# TRON blockchain config
TRON_USDT_CONTRACT=TXLAQ63Xg1NAzckPwKHvzw7CSEmLMEqcdj
TRON_EVENT_API_URL=https://api.trongrid.io
TRON_CONFIRMATIONS_REQUIRED=20

# Wallets
MASTER_HOT_WALLET=                                    # Hot wallet TRON address
HOT_WALLET_PRIVATE_KEY=                               # Hot wallet private key (hex) — NEVER COMMIT THIS
COLD_WALLET=TG3ptMHqpFfVn7fJzwPD8Xzxid6J7txxtq       # Cold wallet — long-term storage
HOT_WALLET_THRESHOLD_USDT=9                           # Transfer to cold when hot balance > this

# Payment Engine
INTERNAL_API_SECRET=CHANGE_ME_STRONG_SECRET            # HMAC secret for webhook signing. Generate: openssl rand -base64 48
PAYMENT_ENGINE_URL=http://localhost:9100
MAIN_PLATFORM_CALLBACK_URL=http://127.0.0.1:8090/internal/payment-events

# Invoice
INVOICE_EXPIRY_MINUTES=30

# ── Bot Limits ─────────────────────────────────────────────────
MAX_BOTS_PER_USER=50

# ── Hub Mode ───────────────────────────────────────────────────
# Faz 1: false (hub runs inside API worker 0)
# Faz 2+: true (hub runs as separate market-hub service)
HUB_EXTERNAL=false

# ── Bot Breaker Thresholds (optional tuning) ───────────────────
# BB_MAX_MARKET_TRADES=50
# BB_MAX_STRATEGY_FAILS=10
# BB_MAX_USER_FAILS=5
