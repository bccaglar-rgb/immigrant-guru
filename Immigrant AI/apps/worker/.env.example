APP_NAME=Immigrant AI Worker
APP_SLUG=immigrant-ai-worker
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://immigrant_ai:immigrant_ai@localhost:5432/immigrant_ai
REDIS_URL=redis://localhost:6379/0
LOCAL_STORAGE_ROOT=./storage
HEARTBEAT_CHANNEL=immigrant-ai:worker:heartbeat
HEARTBEAT_INTERVAL_SECONDS=30
DOCUMENT_PROCESSING_QUEUE_NAME=immigrant-ai:jobs:document-processing
DOCUMENT_PROCESSING_BLOCK_TIMEOUT_SECONDS=5
DOCUMENT_PROCESSING_MAX_RETRIES=3
DOCUMENT_TEXT_PREVIEW_CHARS=2000
