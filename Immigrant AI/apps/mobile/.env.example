# Copy to .env and fill in. Values are compiled into the app at build time.

# Backend API base — no trailing slash
EXPO_PUBLIC_API_URL=https://immigrant.guru/api/v1

# RevenueCat public SDK keys (from dashboard → Projects → API keys)
EXPO_PUBLIC_RC_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxx

# Optional: Sentry error reporting
EXPO_PUBLIC_SENTRY_DSN=
