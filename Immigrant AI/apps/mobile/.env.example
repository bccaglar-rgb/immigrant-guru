# Copy to .env and fill in. Values are compiled into the app at build time.

# Backend API base — no trailing slash
EXPO_PUBLIC_API_URL=https://immigrant.guru/api/v1

# RevenueCat public SDK keys (from dashboard → Projects → API keys)
EXPO_PUBLIC_RC_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_RC_ANDROID_KEY=goog_xxxxxxxxxxxxxxxxxxxx

# Optional: Sentry error reporting
EXPO_PUBLIC_SENTRY_DSN=

# Google Sign-In OAuth client IDs (Google Cloud Console → APIs & Services
# → Credentials). Create one client ID per platform. The web ID is used as
# the audience for the ID token verified by the backend.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=606162264729-v432u04e3adl1jtl1fiig3gnsg1am286.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=606162264729-l46atad9kqudrmlciqdip3vl06qjmut4.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=606162264729-vhft0on0q6uoohg3ll9d4ovedhvirc61.apps.googleusercontent.com
