APP_NAME=Immigrant AI API
APP_SLUG=immigrant-ai-api
APP_ENV=development
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://immigrant_ai:immigrant_ai@localhost:5432/immigrant_ai
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]
ADMIN_EMAILS=["admin@example.com"]
# IPs of trusted reverse proxies. Only these IPs may set X-Forwarded-For.
# Production: set to your Nginx/load-balancer LAN IP (e.g. ["127.0.0.1"])
TRUSTED_PROXY_IPS=[]
# Replace this before staging or production.
JWT_SECRET_KEY=dev-only-change-me-to-a-secure-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=immigrant-ai-api
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Sign in with Google: JSON array of OAuth client IDs (web + iOS + Android)
# from Google Cloud Console — backend accepts ID tokens for any of them.
GOOGLE_OAUTH_CLIENT_IDS=["606162264729-vhft0on0q6uoohg3ll9d4ovedhvirc61.apps.googleusercontent.com","606162264729-l46atad9kqudrmlciqdip3vl06qjmut4.apps.googleusercontent.com","606162264729-v432u04e3adl1jtl1fiig3gnsg1am286.apps.googleusercontent.com"]
# Sign in with Apple: Service ID (web) and/or Bundle ID (mobile) the
# identityToken's `aud` claim must match.
APPLE_OAUTH_CLIENT_IDS=["guru.immigrant.app"]
AI_PROVIDER=disabled
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30
AI_TEMPERATURE=0.2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
LOCAL_STORAGE_ROOT=./storage
DOCUMENT_MAX_UPLOAD_BYTES=26214400
DOCUMENT_PROCESSING_QUEUE_NAME=immigrant-ai:jobs:document-processing
TIMELINE_SNAPSHOT_TTL_MINUTES=720
KNOWLEDGE_RETRIEVAL_BACKEND=hybrid
KNOWLEDGE_SEARCH_CANDIDATE_LIMIT=50
KNOWLEDGE_VECTOR_CANDIDATE_LIMIT=40
KNOWLEDGE_HYBRID_RRF_K=50
KNOWLEDGE_HYBRID_LEXICAL_WEIGHT=0.45
KNOWLEDGE_HYBRID_VECTOR_WEIGHT=0.35
KNOWLEDGE_HYBRID_FRESHNESS_WEIGHT=0.10
KNOWLEDGE_HYBRID_AUTHORITY_WEIGHT=0.10
KNOWLEDGE_EMBEDDING_PROVIDER=hashing
KNOWLEDGE_EMBEDDING_MODEL=hashing-v1
KNOWLEDGE_EMBEDDING_DIMENSIONS=256
FRONTEND_APP_URL=http://localhost:3000
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_WEBHOOK_EVENT_TTL_SECONDS=604800
STRIPE_STARTER_PRICE_ID=
STRIPE_PLUS_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
